locale("us");

let first_name = gen(_firstname);
let last_name = gen(_lastname);

print(first_name);
print(first_name.at(0));
print(first_name.substr(0..2)); //end is exclusive

print(last_name);

let age = randint(0..100);
print(age);

let temp = 1.224;
print(temp);

//80% chance to return true
let active = randbool(0.8);
print(active);

let users = [["Nested"], "Adam", "Felix", "Carol", "Karen", "Jacob"];
print(users);
print(users.at(0).at(0));
print(users.at(1));
