locale("us");

rows(10) {
    table("users") {
        column("id", int, increment(0..));
        column("username", varchar, format("{}@{}_{}", gen(firstname), gen(lastname), random(0..999)));
        column("first_name", varchar, gen(firstname));
        column("last_name", varchar, gen(lastname));
        column("age", int, random(18..99));
        column("sex", varchar, gen(sex));
        column("alive", boolean, gen(boolean));
    }
}
